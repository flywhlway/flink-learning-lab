          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  $__timeInterval(window_start) AS time,\n  sum(event_count) AS event_count\nFROM flinklab.vehicle_window_metrics\nWHERE $__timeFilter(window_start)\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "窗口吞吐 · event_count（ClickHouse）",
      "type": "timeseries"
