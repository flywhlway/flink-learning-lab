          "rawSql": "SELECT\n  $__timeInterval(event_time) AS time,\n  pattern_id,\n  countIf(alert_type = 'MATCH') AS match_count\nFROM flinklab.vehicle_alerts\nWHERE $__timeFilter(event_time)\nGROUP BY time, pattern_id\nORDER BY time",
          "refId": "A"
        }
      ],
